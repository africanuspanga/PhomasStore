{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/health.ts": {
      "maxDuration": 60
    },
    "api/products.ts": {
      "maxDuration": 60
    },
    "api/admin/login.ts": {
      "maxDuration": 60
    },
    "api/admin/orders.ts": {
      "maxDuration": 60
    },
    "api/admin/approve-user.ts": {
      "maxDuration": 60
    },
    "api/admin/users.ts": {
      "maxDuration": 60
    },
    "api/admin/pending-users.ts": {
      "maxDuration": 60
    },
    "api/admin/change-password.ts": {
      "maxDuration": 60
    },
    "api/admin/recover-access.ts": {
      "maxDuration": 60
    },
    "api/[...path].ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.ts"
    },
    {
      "src": "/api/products",
      "dest": "/api/products.ts"
    },
    {
      "src": "/api/admin/login",
      "dest": "/api/admin/login.ts"
    },
    {
      "src": "/api/admin/orders",
      "dest": "/api/admin/orders.ts"
    },
    {
      "src": "/api/admin/approve-user",
      "dest": "/api/admin/approve-user.ts"
    },
    {
      "src": "/api/admin/users",
      "dest": "/api/admin/users.ts"
    },
    {
      "src": "/api/admin/pending-users",
      "dest": "/api/admin/pending-users.ts"
    },
    {
      "src": "/api/admin/change-password",
      "dest": "/api/admin/change-password.ts"
    },
    {
      "src": "/api/admin/recover-access",
      "dest": "/api/admin/recover-access.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
